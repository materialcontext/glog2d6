{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "lib": ["DOM", "ES2022"],
    "types": ["jquery", "fvtt-types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
