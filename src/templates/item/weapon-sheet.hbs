<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'GLOG.Name'}}"/>
      </h1>
    </div>
  </header>

  <!-- Sheet Body -->
  <section class="sheet-body">
    <div class="weapon-properties">
      <div class="form-group">
        <label>{{localize "GLOG.WeaponType"}}</label>
        <div class="form-fields">
          <select name="system.weaponType">
            {{#select system.weaponType}}
            {{#each config.weaponTypes as |name key|}}
            <option value="{{key}}">{{localize name}}</option>
            {{/each}}
            {{/select}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>{{localize "GLOG.Damage"}}</label>
        <div class="form-fields">
          <input type="text" name="system.damage" value="{{system.damage}}"/>
        </div>
      </div>
    </div>

    <div class="weapon-properties">
      <div class="form-group">
        <label>{{localize "GLOG.Range"}}</label>
        <div class="form-fields">
          <input type="text" name="system.range" value="{{system.range}}" data-dtype="Number"/>
        </div>
      </div>

      <div class="form-group">
        <label>{{localize "GLOG.AttackBonus"}}</label>
        <div class="form-fields">
          <input type="text" name="system.attackBonus" value="{{system.attackBonus}}" data-dtype="Number"/>
        </div>
      </div>
    </div>

    {{#if isRanged}}
    <div class="form-group">
      <label>{{localize "GLOG.Reload"}}</label>
      <div class="form-fields">
        <input type="text" name="system.reload" value="{{system.reload}}"/>
      </div>
    </div>
    {{/if}}

    <div class="weapon-properties">
      <div class="form-group">
        <label>{{localize "GLOG.Slots"}}</label>
        <div class="form-fields">
          <input type="text" name="system.slots" value="{{system.slots}}" data-dtype="Number"/>
        </div>
      </div>

      <div class="form-group">
        <label>{{localize "GLOG.Broken"}}</label>
        <div class="form-fields">
          <select name="system.broken">
            {{#select system.broken}}
            <option value="0">{{localize "GLOG.Undamaged"}}</option>
            <option value="1">{{localize "GLOG.Damaged"}}</option>
            <option value="2">{{localize "GLOG.Broken"}}</option>
            {{/select}}
          </select>
        </div>
      </div>
    </div>

    <div class="form-group">
      <label>{{localize "GLOG.Price"}}</label>
      <div class="form-fields">
        <input type="text" name="system.price" value="{{system.price}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="form-group stacked">
      <label class="section-title">{{localize "GLOG.Description"}}</label>
      <div class="form-fields">
        <textarea name="system.description" class="description">{{system.description}}</textarea>
      </div>
    </div>
  </section>
</form>
